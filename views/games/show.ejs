<% layout('./layouts/boilerplate.ejs') %>
<link rel="stylesheet" href="/css/show.css">

<div class="game-details">
    <h1><%= game.name %></h1>

    <!-- Game Cover Image -->
    <img src="<%= game.cover ? `https://images.igdb.com/igdb/image/upload/t_cover_big/${game.cover.image_id}.jpg` : 'https://i.ytimg.com/vi/m8i5JuwI_V0/hqdefault.jpg' %>" alt="<%= game.name %>" class="game-cover">

    <!-- Game Summary -->
    <h2>Summary</h2>
    <p><%= game.summary %></p>

    <!-- Game Rating -->
    <h3>Rating: <%= game.rating ? game.rating.toFixed(1) : 'N/A' %></h3>
    <h3>Rating Count: <%= game.rating_count %></h3>

    <!-- Platforms -->
    <h3>Available on:</h3>
    <ul>
        <% game.platforms.forEach(platform => { %>
            <li><%= platform.abbreviation %></li>
        <% }) %>
    </ul>

    <!-- Release Dates by Platform -->
    <h3>Release Dates</h3>
    <ul>
        <% game.release_dates.forEach(release => { %>
            <li>
                <%= release.platform.abbreviation %>: 
                <%= new Date(release.date * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </li>
        <% }) %>
    </ul>

    <!-- Game Storyline -->
    <h2>Storyline</h2>
    <p><%= game.storyline %></p>

    <!-- Themes -->
    <h3>Themes</h3>
    <ul>
        <% game.themes.forEach(theme => { %>
            <li><%= theme.slug.replace(/-/g, ' ') %></li>
        <% }) %>
    </ul>

    <!-- Screenshots -->
    <h2>Screenshots</h2>
    <div id="screenshots" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
        <% if (game.screenshots.length > 1) { %>
            <ol class="carousel-indicators">
                <% game.screenshots.forEach((_, i) => { %>
                    <li data-bs-target="#screenshots" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>"></li>
                <% }) %>
            </ol>
        <% } %>

        <div class="carousel-inner">
            <% game.screenshots.forEach((img, i) => { %>
                <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                    <img crossorigin="anonymous" class="d-block w-100" src="https://images.igdb.com/igdb/image/upload/t_screenshot_big/<%= img.image_id %>.jpg" alt="Screenshot <%= i + 1 %>">
                </div>
            <% }) %>
        </div>

        <% if (game.screenshots.length > 1) { %>
            <a class="carousel-control-prev" href="#screenshots" role="button" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </a>
            <a class="carousel-control-next" href="#screenshots" role="button" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </a>
        <% } %>
    </div>

</div>
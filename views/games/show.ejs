<% layout('./layouts/boilerplate.ejs') %>
<link rel="stylesheet" href="/css/show.css">

<div class="game-details">
    <h1><%= game.name %></h1>

    <!-- Game Cover Image -->
    <img src="<%= game.cover ? `https://images.igdb.com/igdb/image/upload/t_cover_big/${game.cover.image_id}.jpg` : 'https://i.ytimg.com/vi/m8i5JuwI_V0/hqdefault.jpg' %>" alt="<%= game.name %>" class="game-cover">
    
    <!-- Dropdown Button using Bootstrap 5 -->
    <div class="row align-items-center">
        <!-- Dropdown Button -->
        <div class="dropdown col-auto pe-0">
            <button class="btn dropdown-toggle <%= status === 'completed' ? 'bg-warning text-dark' : status === 'playing' ? 'bg-success text-white' : status === 'on hold' ? 'bg-secondary text-white' : status === 'dropped' ? 'bg-danger text-white' : status === 'ToPlay' ? 'bg-primary text-white' : 'btn-secondary' %>" 
                    type="button" 
                    id="dropdownMenuButton" 
                    data-bs-toggle="dropdown" 
                    aria-expanded="false">
                <span class="mx-5"><%= status ? status : 'Add to list' %></span>
            </button>
            <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                <!-- ToPlay -->
                <li>
                    <form action="/games/<%= game.id %>/add-to-list/ToPlay" method="POST" style="display: inline;">
                        <button type="submit" class="dropdown-item">ToPlay</button>
                    </form>
                </li>
                <!-- Completed -->
                <li>
                    <form action="/games/<%= game.id %>/add-to-list/completed" method="POST" style="display: inline;">
                        <button type="submit" class="dropdown-item">Completed</button>
                    </form>
                </li>
                <!-- Dropped -->
                <li>
                    <form action="/games/<%= game.id %>/add-to-list/dropped" method="POST" style="display: inline;">
                        <button type="submit" class="dropdown-item">Dropped</button>
                    </form>
                </li>
                <!-- Playing -->
                <li>
                    <form action="/games/<%= game.id %>/add-to-list/playing" method="POST" style="display: inline;">
                        <button type="submit" class="dropdown-item">Playing</button>
                    </form>
                </li>
                <!-- On Hold -->
                <li>
                    <form action="/games/<%= game.id %>/add-to-list/on-hold" method="POST" style="display: inline;">
                        <button type="submit" class="dropdown-item">On Hold</button>
                    </form>
                </li>
            </ul>
        </div>
<!-- Heart Button -->
<div class="col-auto pe-1">
    <% if (currentUser.favoriteGames.includes(game.id)) { %>
        <form action="/games/<%= game.id %>/unfavorite" method="POST">
            <button class="btn btn-danger" title="Remove from favorites">
                <span class="fw-bold">❤️</span> 
            </button>
        </form>
    <% } else { %>
        <form action="/games/<%= game.id %>/favorite" method="POST">
            <button class="btn btn-outline-danger" title="Add to favorites">
                <span class="fw-bold">🤍</span> 
            </button>
        </form>
    <% } %>
</div>

    </div>

    <!-- Game Summary -->
    <h2>Summary</h2>
    <p><%= game.summary %></p>

    <!-- Game Rating -->
    <h3>Rating: <%= game.rating ? game.rating.toFixed(1) : 'N/A' %></h3>
    <h3>Rating Count: <%= game.rating_count %></h3>

    <!-- Platforms -->
    <h3>Available on:</h3>
<ul>
    <% if (game.platforms && Array.isArray(game.platforms)) { %>
        <% game.platforms.forEach(platform => { %>
            <li><%= platform.abbreviation %></li>
        <% }) %>
    <% } else { %>
        <li>No platforms available</li>
    <% } %>
</ul>

    <!-- Release Dates by Platform -->
<h3>Release Dates</h3>
<ul>
    <% if (game.release_dates && Array.isArray(game.release_dates)) { %>
        <% game.release_dates.forEach(release => { %>
            <li>
                <%= release.platform.abbreviation %>: 
                <%= new Date(release.date * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </li>
        <% }) %>
    <% } else { %>
        <li>No release dates available</li>
    <% } %>
</ul>


    <!-- Game Storyline -->
    <h2>Storyline</h2>
    <p><%= game.storyline %></p>

    <!-- Themes -->
    <h3>Themes</h3>
    <ul>
        <% game.themes.forEach(theme => { %>
            <li><%= theme.slug.replace(/-/g, ' ') %></li>
        <% }) %>
    </ul>

    <!-- Screenshots -->
    <h2>Screenshots</h2>
    <div id="screenshots" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
        <% if (game.screenshots.length > 1) { %>
            <ol class="carousel-indicators">
                <% game.screenshots.forEach((_, i) => { %>
                    <li data-bs-target="#screenshots" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>"></li>
                <% }) %>
            </ol>
        <% } %>

        <div class="carousel-inner">
            <% game.screenshots.forEach((img, i) => { %>
                <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                    <img crossorigin="anonymous" class="d-block w-100" src="https://images.igdb.com/igdb/image/upload/t_screenshot_big/<%= img.image_id %>.jpg" alt="Screenshot <%= i + 1 %>">
                </div>
            <% }) %>
        </div>

        <% if (game.screenshots.length > 1) { %>
            <a class="carousel-control-prev" href="#screenshots" role="button" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </a>
            <a class="carousel-control-next" href="#screenshots" role="button" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </a>
        <% } %>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/javascripts/searchBar.js"></script>
<link rel="stylesheet" href="/css/search.css">

<nav class="navbar navbar-expand-lg sticky-top bg-dark text-light" data-bs-theme="dark">
    <div class="container-fluid">
        <!-- Brand name aligned to the left -->
        <a class="navbar-brand" href="/">PassionFlow</a>
        
        <!-- Toggle button for mobile view -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <!-- Navbar content collapsible for smaller screens -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <!-- Left-aligned links -->
            <ul class="navbar-nav me-5 ms-5">
                <li class="nav-item">
                    <a class="nav-link active" aria-current="page" href="/games">Games</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="/games/myGames?category=allGames">My Games</a>
                </li>
            </ul>

            <!-- Centered search bar with better alignment -->
            <div id="search-container" class="position-relative" style="width: 50%; margin: 0 auto;">
                <form id="search-form" action="/games/search" method="POST" class="d-flex align-items-center" role="search">
                    <input id="search" class="form-control me-2" type="search" name="game[name]" placeholder="Search for a game..." 
                           aria-label="Search for a game" required autocomplete="off">
                    <button class="btn btn-outline-success" type="submit">Search</button>
                </form>

                <!-- Container for search results positioned below the search bar -->
                <div id="search-results" class="bg-light border position-absolute w-100" style="max-height: 600px; overflow-y: auto; z-index: 1000;"></div>
            </div>

            <!-- Right-aligned user dropdown -->
            <ul class="navbar-nav ms-auto">
                <li class="nav-item dropdown">
                    <% if (!currentUser) { %>
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true">
                            <img src="https://pngimg.com/uploads/pacman/pacman_PNG28.png" alt="Guest icon" style="width: 20px; height: 20px;">
                            Guest
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/login">Login</a></li>
                            <li><a class="dropdown-item" href="/register">Register</a></li>
                        </ul>
                    <% } else { %>
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true">
                            <img src="<%= currentUser.profileImage[0]?.url %>" alt="User icon" style="width: 20px; height: 20px;">
                            <%= currentUser.username %>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/profile">Profile</a></li>
                            <li><a class="dropdown-item" href="/friends">Friends</a></li>
                            <li>
                                <form class="dropdown-item m-0 p-0" action="/logout?_method=DELETE" method="POST">
                                    <button type="submit" class="btn btn-link text-decoration-none">Logout</button>
                                </form>
                            </li>
                        </ul>
                    <% } %>
                </li>
            </ul>
        </div>
    </div>
</nav>
<script src="/javascripts/searchBar.js"></script>
